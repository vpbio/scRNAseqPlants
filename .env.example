# =============================================================================
# STARsolo Pipeline - Environment Variables (rename to .env after filling details)
# =============================================================================

# --- Genome indices (STAR index directories) ---
GENOME_INDEX_AT=
GENOME_INDEX_OS=
GENOME_INDEX_AT_OS=
GENOME_INDEX_AT_GFP=
GENOME_INDEX_AT_HS=
GENOME_INDEX_AT_MM=

# --- CellRanger installation root ---
# Barcodes are resolved as $CELLRANGER_LOCATION/lib/python/cellranger/barcodes/
CELLRANGER_LOCATION=

# --- STAR binary ---
STAR_BIN=
